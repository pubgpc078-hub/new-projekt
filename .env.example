# ───────────────────────────────────────────────────────────────
# Manojan Kala — Environment Configuration
# Copy this file to `.env` and adjust the values for your setup.
# ───────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Public base URL (used for SEO canonical/OG tags and absolute links)
PUBLIC_URL=http://localhost:3000

# Database (relative to project root)
DB_PATH=data/manojan_kala.db

# Security — CHANGE THESE IN PRODUCTION
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=mk_token

# Bcrypt cost factor
BCRYPT_ROUNDS=10

# CORS — comma separated list of allowed origins, or * for any
CORS_ORIGINS=*

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# ───────────────────────────────────────────────────────────────
# n8n Automation Layer
# Create webhooks in n8n and paste their URLs here. Leave blank to
# disable a given automation. All calls are fire-and-forget and never
# block the customer-facing request.
# ───────────────────────────────────────────────────────────────
N8N_ENABLED=false
N8N_ORDER_CREATED_WEBHOOK=
N8N_ORDER_STATUS_WEBHOOK=
N8N_LOW_STOCK_WEBHOOK=
N8N_USER_REGISTERED_WEBHOOK=
# Optional shared secret sent as the `X-Webhook-Signature` header
N8N_WEBHOOK_SECRET=

# Low-stock threshold that triggers an inventory alert automation
LOW_STOCK_THRESHOLD=5

# Default admin account created during seeding
SEED_ADMIN_EMAIL=admin@manojankala.com
SEED_ADMIN_PASSWORD=Admin@12345
